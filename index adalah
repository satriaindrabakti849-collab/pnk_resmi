<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PNK - Perlindungan Nusantara Komunitas</title>
    <style>
        :root {
            --primary: #007bff;
            --dark: #1a1a1a;
            --gold: #ffd700;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle, #2c3e50, #000000);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: 90%;
            max-width: 500px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        h1 { color: var(--gold); margin-bottom: 10px; }
        p { font-size: 0.9em; opacity: 0.8; }

        .form-group { text-align: left; margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-size: 0.8em; }
        
        input, select, textarea {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.9);
            box-sizing: border-box;
        }

        .ai-badge {
            background: linear-gradient(45deg, #00f2fe, #4facfe);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.7em;
            display: inline-block;
            margin: 10px 0;
            font-weight: bold;
            text-transform: uppercase;
        }

        .btn-next {
            background: var(--primary);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            width: 100%;
            margin-top: 20px;
        }

        .btn-next:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px var(--primary);
        }

        .hidden { display: none; }

        /* Animasi */
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate { animation: slideIn 0.5s ease forwards; }
    </style>
</head>
<body>

    <audio id="clickSound" src="https://www.soundjay.com/buttons/sounds/button-3.mp3" preload="auto"></audio>

    <div id="page1" class="container animate">
        <h1>PNK</h1>
        <h3>Perlindungan Nusantara Komunitas</h3>
        <div class="ai-badge">Sistem Keamanan AI Aktif</div>
        <p>Selamat datang di gerbang komunitas nusantara. Kami menggunakan enkripsi tingkat tinggi dan kecerdasan buatan untuk menjaga privasi Anda.</p>
        <button class="btn-next" onclick="nextPage(2)">LANJUTKAN</button>
    </div>

    <div id="page2" class="container hidden">
        <h2>Data Diri Anggota</h2>
        <div class="form-group">
            <label>Nama Lengkap</label>
            <input type="text" id="nama" placeholder="Masukkan nama...">
        </div>
        <div class="form-group">
            <label>Umur & Tanggal Lahir</label>
            <input type="date" id="tgl_lahir">
        </div>
        <div class="form-group">
            <label>Jenis Kelamin</label>
            <select id="jk">
                <option value="Laki-laki">Laki-laki</option>
                <option value="Perempuan">Perempuan</option>
            </select>
        </div>
        <div class="form-group">
            <label>Asal Daerah</label>
            <input type="text" id="asal" placeholder="Contoh: Jakarta">
        </div>
        <div class="form-group">
            <label>Username TikTok</label>
            <input type="text" id="tiktok" placeholder="@username">
        </div>
        <div class="form-group">
            <label>Alasan Bergabung</label>
            <textarea id="alasan" rows="3"></textarea>
        </div>
        <button class="btn-next" onclick="joinGroup()">DAFTAR & MASUK GRUP</button>
    </div>

    <script>
        function playSound() {
            const sound = document.getElementById('clickSound');
            sound.currentTime = 0;
            sound.play();
        }

        function nextPage(page) {
            playSound();
            document.getElementById('page1').classList.add('hidden');
            const p2 = document.getElementById('page2');
            p2.classList.remove('hidden');
            p2.classList.add('animate');
        }

        function joinGroup() {
            playSound();
            const nama = document.getElementById('nama').value;
            
            if(nama === "") {
                alert("Harap lengkapi nama Anda.");
                return;
            }

            alert("Sistem AI memverifikasi data... Keamanan diperketat!");
            
            // Redirect otomatis ke grup WA setelah 1.5 detik
            setTimeout(() => {
                window.location.href = "https://chat.whatsapp.com/KJQGOzP9OazAF3MbyUFx65?mode=gi_t";
            }, 1500);
        }
    </script>
</body>
</html>
